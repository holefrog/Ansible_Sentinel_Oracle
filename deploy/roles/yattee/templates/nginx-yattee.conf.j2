# HTTP Challenge and Redirect
server {
    listen 80;
    server_name {{ yattee_domain }};
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS Server
server {
    listen 4433 ssl http2;
    server_name {{ yattee_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ yattee_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ yattee_domain }}/privkey.pem;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_read_timeout 3600s;
        client_max_body_size 100M;
    }

    location /static/ {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/static/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location /favicon.ico {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/favicon.ico;
    }
}
