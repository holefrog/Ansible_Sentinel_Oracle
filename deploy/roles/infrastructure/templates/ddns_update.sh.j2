#!/bin/bash
# 自动生成的 ChangeIP DDNS 更新脚本
DOMAIN="{{ domain }}"
USER="{{ changeip_username }}"
PASS="{{ changeip_password }}"

IP=$(curl -s https://api.ipify.org || curl -s https://ipv4.icanhazip.com)
if [ -z "$IP" ]; then
    echo "$(date) - 无法获取公网 IP"
    exit 1
fi

RESPONSE=$(curl -s -u "$USER:$PASS" "https://nic.changeip.com/nic/update?u=$USER&p=$PASS&hostname=$DOMAIN&myip=$IP")
echo "$(date) - IP: $IP - Response: $RESPONSE"

{% if yattee_domain is defined %}
# 更新 yattee 子域名
RESPONSE_YATTEE=$(curl -s -u "$USER:$PASS" "https://nic.changeip.com/nic/update?u=$USER&p=$PASS&hostname={{ yattee_domain }}&myip=$IP")
echo "$(date) - IP: $IP - yattee Response: $RESPONSE_YATTEE"
{% endif %}
